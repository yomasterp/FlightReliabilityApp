# Copy to .env and fill in secrets. Required: AVIATIONSTACK_API_KEY

AVIATIONSTACK_API_KEY=
AVIATIONSTACK_BASE_URL=https://api.aviationstack.com/v1

# --- Database (choose one style) ---

# A) Full URI (recommended for Supabase: paste "URI" from Project Settings → Database)
#    You can use postgresql:// or postgres://; it is normalized to psycopg2.
#    For running `python -m src.init_database` / `schema_upgrade`, prefer the direct DB
#    connection (port 5432). Transaction pooler (6543) can interfere with CREATE INDEX.
# SQLALCHEMY_DATABASE_URL=

# B) Or set host pieces (local dev or scripted). Remote hosts get sslmode=require unless overridden.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=flight_reliability

# Optional: force libpq sslmode on any URL (e.g. verify-full). Appended if missing.
# DB_SSLMODE=require
